{
  "name": "@originaryx/agent-auditor-core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./bundle/node": {
      "types": "./dist/bundle/bundle.node.d.ts",
      "import": "./dist/bundle/bundle.node.mjs",
      "require": "./dist/bundle/bundle.node.cjs"
    },
    "./bundle/web": {
      "types": "./dist/bundle/bundle.web.d.ts",
      "import": "./dist/bundle/bundle.web.mjs",
      "require": "./dist/bundle/bundle.web.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@peac/crypto": "^0.12.0",
    "@peac/kernel": "^0.12.0",
    "@peac/protocol": "^0.12.0",
    "@peac/schema": "^0.12.0"
  },
  "devDependencies": {
    "@peac/audit": "^0.12.0",
    "jszip": "^3.10.1",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "@peac/audit": "^0.12.0",
    "jszip": "^3.10.1"
  },
  "peerDependenciesMeta": {
    "@peac/audit": {
      "optional": true
    },
    "jszip": {
      "optional": true
    }
  }
}
